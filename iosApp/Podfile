# This Podfile is managed by the KMP CocoaPods Gradle plugin.
#
# DO NOT edit the ComposeApp pod line — it is regenerated by:
#   ./gradlew :composeApp:podInstall
#
# To add new pods, add them here AND declare them in composeApp/build.gradle.kts
# inside the cocoapods {} block so the cinterop bindings are generated.

source 'https://cdn.cocoapods.org'

platform :ios, '14.0'
use_frameworks!

target 'iosApp' do
  # KMP framework — path points to the composeApp module where the .podspec is generated
  pod 'composeApp', :path => '../composeApp/'

  # WebRTC native framework — Stream's maintained xcframework (WebRTC M137)
  # with proper arm64-simulator slice. No more Rosetta workaround needed.
  pod 'StreamWebRTC', '~> 137.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # Xcode build phase shells don't inherit the user's JAVA_HOME.
      # Exposing it as a build setting makes it available to the Gradle
      # syncFramework script that the KMP CocoaPods plugin injects.
      config.build_settings['JAVA_HOME'] = '/Applications/Android Studio.app/Contents/jbr/Contents/Home'
      config.build_settings['PATH'] = '/Applications/Android Studio.app/Contents/jbr/Contents/Home/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin'
    end
  end
end
